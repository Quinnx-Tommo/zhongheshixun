<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.training.mapper.KnowledgeBaseMapper">

    <resultMap id="BaseResultMap" type="com.training.common.entity.KnowledgeBase">
        <id column="id" property="id"/>
        <result column="question" property="question"/>
        <result column="answer" property="answer"/>
        <result column="keywords" property="keywords"/>
        <result column="category" property="category"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="matchByKeywords" resultMap="BaseResultMap">
        SELECT * FROM knowledge_base
        WHERE deleted = 0
        AND (
            <foreach collection="keywords" item="kw" separator=" OR ">
                keywords LIKE CONCAT('%', #{kw}, '%') OR question LIKE CONCAT('%', #{kw}, '%')
            </foreach>
        )
        ORDER BY create_time DESC
        LIMIT 1
    </select>

</mapper>
