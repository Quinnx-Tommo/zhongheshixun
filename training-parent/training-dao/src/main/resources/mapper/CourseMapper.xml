<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.training.mapper.CourseMapper">

    <resultMap id="BaseResultMap" type="com.training.common.entity.Course">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="teacher_id" property="teacherId"/>
        <result column="course_type" property="courseType"/>
        <result column="total_hours" property="totalHours"/>
        <result column="status" property="status"/>
        <result column="offline_flag" property="offlineFlag"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectCoursePage" resultMap="BaseResultMap">
        SELECT * FROM course
        <where>
            deleted = 0
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="courseType != null">
                AND course_type = #{courseType}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectEnrolledCourses" resultMap="BaseResultMap">
        SELECT c.* FROM course c
        INNER JOIN course_enroll e ON e.course_id = c.id
        WHERE c.deleted = 0
          AND e.deleted = 0
          AND e.student_id = #{studentId}
        ORDER BY e.create_time DESC
    </select>

    <!-- 推荐课程：按报名数降序，报名数相同按创建时间降序 -->
    <select id="selectRecommend" resultMap="BaseResultMap">
        SELECT c.*
        FROM course c
        LEFT JOIN (
            SELECT course_id, COUNT(*) AS cnt
            FROM course_enroll WHERE deleted = 0
            GROUP BY course_id
        ) e ON e.course_id = c.id
        WHERE c.deleted = 0 AND c.status = 1
        ORDER BY IFNULL(e.cnt, 0) DESC, c.create_time DESC
        LIMIT #{limit}
    </select>

</mapper>
