<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.training.mapper.CourseChapterMapper">

    <resultMap id="BaseResultMap" type="com.training.common.entity.CourseChapter">
        <id column="id" property="id"/>
        <result column="course_id" property="courseId"/>
        <result column="title" property="title"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="video_url" property="videoUrl"/>
        <result column="duration" property="duration"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectChapterPage" resultMap="BaseResultMap">
        SELECT * FROM course_chapter
        <where>
            deleted = 0
            AND course_id = #{courseId}
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
        </where>
        ORDER BY sort_order ASC, id ASC
    </select>

</mapper>
