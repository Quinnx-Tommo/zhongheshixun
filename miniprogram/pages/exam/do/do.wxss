/* pages/exam/do/do.wxss */
.do-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

/* 顶部 */
.do-header {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--border);
}

.do-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 20rpx;
}

.do-timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f0f5ff;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
}

.do-timer.warning {
  background: #fff1f0;
}

.timer-icon {
  font-size: 24rpx;
}

.timer-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
  font-family: monospace;
}

.do-timer.warning .timer-text {
  color: var(--danger);
}

/* 进度条 */
.progress-bar {
  background: #fff;
  padding: 16rpx 32rpx 24rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.progress-track {
  height: 8rpx;
  background: var(--border);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 题目区 */
.question-area {
  flex: 1;
  background: #fff;
  margin: 20rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.q-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: var(--primary);
  background: #f0f5ff;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.q-title {
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-item.selected {
  background: #f0f5ff;
  border-color: var(--primary);
}

.option-marker {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-marker.selected {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.option-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  flex: 1;
}

/* 填空 */
.fill-blank {
  margin-top: 16rpx;
}

.blank-input {
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 24rpx;
  font-size: 28rpx;
}

/* 底部操作栏 */
.do-footer {
  background: #fff;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid var(--border);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg);
  border-radius: 999rpx;
}

.nav-btn.disabled {
  color: var(--text-muted);
  opacity: 0.5;
}

.submit-btn {
  flex: 1.5;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border-radius: 999rpx;
}
