/* pages/profile/records/records.wxss */
/* 学习记录 — 考试记录时间线 */

.page {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 时间线容器 */
.timeline {
  padding: 20rpx 0;
}

/* 每个时间线项 */
.timeline-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 0;
  position: relative;
}

/* 左侧圆点 + 竖线 */
.timeline-left {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--border);
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx var(--border);
  z-index: 1;
  flex-shrink: 0;
}
/* 通过 → 绿色圆点；未通过 → 灰色圆点 */
.timeline-item.passed .dot {
  background: var(--success);
  box-shadow: 0 0 0 2rpx var(--success);
}
.timeline-item.failed .dot {
  background: var(--text-muted);
  box-shadow: 0 0 0 2rpx var(--text-muted);
}
.line {
  width: 2rpx;
  flex: 1;
  background: var(--border);
  margin: 8rpx 0;
}

/* 右侧卡片 */
.card {
  flex: 1;
  margin-left: 8rpx;
  margin-bottom: 30rpx;
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.card-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 通过/未通过 徽标 */
.badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}
.badge-pass {
  background: #f6ffed;
  color: var(--success);
}
.badge-fail {
  background: #fff2f0;
  color: var(--danger);
}

/* 卡片中部统计 */
.card-body {
  display: flex;
  gap: 30rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border);
}
.stat {
  display: flex;
  flex-direction: column;
}
.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}
.stat-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-top: 4rpx;
}

/* 卡片底部 */
.card-footer {
  border-top: 1rpx solid var(--border);
  padding-top: 12rpx;
  margin-top: 8rpx;
}
.submit-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 空态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.empty-tip {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 骨架屏 */
.skeleton-card {
  padding: 24rpx;
}
