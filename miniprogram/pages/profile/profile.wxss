/* miniprogram/pages/profile/profile.wxss */
.profile-page {
  padding-bottom: 40rpx;
}

/* 用户信息卡 */
.user-card {
  position: relative;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  overflow: hidden;
}
.user-bg {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}
.user-body {
  position: relative;
  display: flex;
  align-items: center;
}
.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: bold;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
}
.avatar image {
  width: 100%;
  height: 100%;
}
.user-meta {
  margin-left: 24rpx;
  flex: 1;
}
.real-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.org-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* 学习数据卡 */
.stats-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}
.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary);
}
.stats-grid {
  display: flex;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary);
}
.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* 功能菜单 */
.menu-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 24rpx;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* 退出登录 */
.logout-btn {
  margin: 40rpx 20rpx;
  background: #fff;
  color: var(--danger);
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 编辑资料弹窗 */
.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}
.edit-sheet {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.form-label {
  width: 140rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}
.form-input {
  flex: 1;
  font-size: 28rpx;
}
.picker-text {
  color: var(--text-primary);
}
.sheet-actions {
  display: flex;
  margin-top: 30rpx;
  gap: 20rpx;
}
.sheet-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
}
.sheet-btn.cancel {
  background: #f5f5f5;
  color: var(--text-secondary);
}
.sheet-btn.confirm {
  background: var(--primary);
  color: #fff;
}
