/* pages/course/my-courses/my-courses.wxss */
/* 我的学习 — 复用 app.wxss 的 CSS 变量 */

.page {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 课程卡片 */
.course-card {
  display: flex;
  flex-direction: row;
  padding: 20rpx;
  margin: 20rpx 0;
}

/* 封面 */
.cover {
  width: 220rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.cover-placeholder {
  background: var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-placeholder-text {
  font-size: 60rpx;
}

/* 右侧信息 */
.info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

/* 标题行 */
.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

/* 徽标 */
.badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}
.badge-required {
  background: #fff2e8;
  color: #fa541c;
}
.badge-optional {
  background: #e6f4ff;
  color: var(--primary);
}

/* 进度条 */
.progress-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--border);
  border-radius: 999rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}
.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
  flex-shrink: 0;
  min-width: 60rpx;
  text-align: right;
}

/* 底部行动行 */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}
.meta {
  font-size: 22rpx;
  color: var(--text-muted);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.btn-study {
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

/* 骨架屏卡片 */
.skeleton-card {
  margin: 20rpx 0;
}

/* 空态（与 app.wxss 保持一致的结构） */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.empty-tip {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: var(--text-muted);
}
