/* pages/course/detail/detail.wxss */
.course-detail-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

/* 课程封面 */
.course-cover {
  width: 100%;
  height: 360rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

/* 课程基本信息 */
.course-info {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.course-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.course-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}
.course-tag {
  display: inline-block;
  background: #e6f7ff;
  color: #1677ff;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 16rpx;
}
.course-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 通用 section */
.section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary);
}
.progress-tip {
  font-size: 26rpx;
  color: #52c41a;
  background: #f0fae5;
  padding: 16rpx;
  border-radius: 8rpx;
}

/* 章节列表 */
.chapter-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.chapter-item:last-child {
  border-bottom: none;
}
.chapter-index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f3f7;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  margin-right: 24rpx;
}
.chapter-info {
  flex: 1;
}
.chapter-title {
  font-size: 28rpx;
  font-weight: 500;
}
.chapter-duration {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}
.chapter-progress {
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 6rpx;
}
.chapter-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* 底部固定操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.btn-enroll {
  flex: 1;
  background: #fff;
  color: var(--primary);
  border: 1rpx solid var(--primary);
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
}
.btn-enroll.enrolled {
  background: #f0fae5;
  color: #52c41a;
  border-color: #52c41a;
}
.btn-learn {
  flex: 2;
  background: var(--primary);
  color: #fff;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-muted);
}
