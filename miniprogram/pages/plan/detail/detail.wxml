<!-- miniprogram/pages/plan/detail/detail.wxml -->
<!-- 培训计划详情页：头部卡 + 统计小卡 + 课程列表 -->

<!-- 加载中：骨架屏 -->
<view wx:if="{{loading}}" class="page">
  <view class="card skeleton-card">
    <view class="skeleton" style="height:40rpx;width:60%;margin-bottom:20rpx"></view>
    <view class="skeleton" style="height:28rpx;width:80%;margin-bottom:12rpx"></view>
    <view class="skeleton" style="height:28rpx;width:70%;margin-bottom:20rpx"></view>
    <view class="skeleton" style="height:16rpx;width:100%;border-radius:999rpx"></view>
  </view>
  <view class="card skeleton-card">
    <view class="skeleton" style="height:160rpx;width:100%"></view>
  </view>
</view>

<!-- 加载完成 -->
<view wx:elif="{{plan}}" class="page">
  <!-- 计划头部卡 -->
  <view class="card header-card">
    <view class="header-title">{{plan.title}}</view>
    <view class="header-desc">{{plan.description || '暂无描述'}}</view>
    <view class="header-time">
      <text class="time-label">培训周期</text>
      <text class="time-range">{{plan.startTime}} ~ {{plan.endTime}}</text>
    </view>
    <!-- 整体进度条 -->
    <view class="progress-row">
      <view class="progress-bar">
        <view class="progress-inner" style="width: {{plan.progress}}%"></view>
      </view>
      <view class="progress-text">
        {{plan.completedCount}} / {{plan.totalCount}} 已完成
      </view>
    </view>
    <view class="progress-pct">总体进度 {{plan.progress}}%</view>
  </view>

  <!-- 统计小卡 -->
  <view class="stats-card">
    <view class="stats-item">
      <view class="stats-num">{{plan.totalCount}}</view>
      <view class="stats-label">总课程</view>
    </view>
    <view class="stats-item">
      <view class="stats-num text-success">{{plan.completedCount}}</view>
      <view class="stats-label">已完成</view>
    </view>
    <view class="stats-item">
      <view class="stats-num text-primary">{{plan.progress}}%</view>
      <view class="stats-label">进度</view>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="section-title">计划课程（共 {{courseList.length}} 节）</view>

  <view wx:if="{{courseList.length > 0}}" class="course-list">
    <view
      class="course-card {{item.completed ? 'done' : ''}}"
      wx:for="{{courseList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goCourseDetail">
      <!-- 左侧圆形序号 -->
      <view class="course-index">{{index + 1}}</view>
      <!-- 中间：标题 + 标签 + 学时 -->
      <view class="course-info">
        <view class="course-title ellipsis-2">{{item.title}}</view>
        <view class="course-meta">
          <text class="course-tag {{item.courseType === 2 ? 'required' : ''}}">{{item.courseTypeText || (item.courseType === 2 ? '必修课' : '公开课')}}</text>
          <text class="course-teacher">{{item.teacherName || '专家团队'}}</text>
          <text class="course-hours">{{item.totalHours}}学时</text>
        </view>
      </view>
      <!-- 右侧：查看按钮 -->
      <view class="course-action">
        <button
          class="btn-primary btn-sm"
          data-id="{{item.id}}"
          catchtap="onViewCourse">查看课程</button>
      </view>
    </view>
  </view>

  <!-- 空态 -->
  <view wx:else class="empty">
    <view class="empty-icon">📋</view>
    <view class="empty-text">该计划暂无课程</view>
  </view>
</view>
