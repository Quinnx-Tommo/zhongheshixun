/* miniprogram/pages/plan/detail/detail.wxss */
/* 培训计划详情页样式 — 复用 app.wxss 设计 token + plan.wxss 视觉风格 */

.page {
  padding-bottom: 40rpx;
}

/* 骨架屏卡片 */
.skeleton-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin: 20rpx;
}

/* ========== 计划头部卡 ========== */
.header-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 30rpx 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}
.header-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}
.header-time {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.time-label {
  font-size: 24rpx;
  color: var(--text-muted);
}
.time-range {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 进度条 */
.progress-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 999rpx;
  overflow: hidden;
}
.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), #4096ff);
  border-radius: 999rpx;
  transition: width 0.4s;
}
.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}
.progress-pct {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ========== 统计小卡 ========== */
.stats-card {
  display: flex;
  background: var(--card-bg);
  margin: 0 20rpx 20rpx;
  border-radius: var(--radius);
  padding: 30rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.stats-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid var(--border);
}
.stats-item:last-child {
  border-right: none;
}
.stats-num {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary);
}
.stats-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}
.text-success { color: var(--success); }
.text-primary { color: var(--primary); }

/* ========== 标题 ========== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 30rpx 30rpx 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary);
}

/* ========== 课程列表 ========== */
.course-list {
  padding: 0 20rpx;
}
.course-card {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}
/* 已完成课程：绿色左侧竖线装饰 */
.course-card.done::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: var(--success);
  border-radius: 6rpx 0 0 6rpx;
}

/* 圆形序号 */
.course-index {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e6f7ff;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 中间信息 */
.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
.course-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.4;
}
.course-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.course-tag {
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
}
.course-tag.required {
  background: #fff4e6;
  color: #fa8c16;
}

/* 右侧按钮 */
.course-action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}
.btn-sm {
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  white-space: nowrap;
}

/* ========== 空态 ========== */
.empty {
  text-align: center;
  color: var(--text-muted);
  padding: 100rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
}
